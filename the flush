#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <Wire.h>
#include "MAX30105.h"
#include "heartRate.h" 
#include "spo2_algorithm.h" 

char ssid[] = "HONOR Pad X8a";
char pass[] = "Alamoo88";

MAX30105 particleSensor;
BlynkTimer timer;
WidgetTerminal terminal(V6);

// BPM Variables
long lastBeat = 0;  
float beatsPerMinute;
int beatAvg = 0;  
int rateSpot = 0;
byte rates[4];

// SpO2 Variables (ลดขนาดตัวแปรลงให้คำนวณไวขึ้น)
uint32_t irBuffer[100];  
uint32_t redBuffer[100]; 
int bufferIndex = 0; // ตัวนับว่าตอนนี้เก็บได้กี่ค่าแล้ว
int32_t spo2;           
int8_t validSPO2;       
int32_t heartRate;      
int8_t validHeartRate;
int sp02Avg = 0;        

void checkHealthAI() {
  long irValue = particleSensor.getIR();  
  if (irValue < 50000) {
    Blynk.virtualWrite(V0, 0);  
    beatAvg = 0;                
    sp02Avg = 0;                
    bufferIndex = 0; // เอานิ้วออก ให้ล้างค่าที่สะสมมาทิ้งไป
    terminal.println("Doctor AI: กรุณาสวมถุงมือให้กระชับครับ");
    Blynk.virtualWrite(V1, 0);  
    Blynk.virtualWrite(V2, 0);  
  } else {
    Blynk.virtualWrite(V0, 255);  
    Blynk.virtualWrite(V1, beatAvg);
    Blynk.virtualWrite(V2, sp02Avg); 

    if (beatAvg > 100) {
      terminal.println("Warning: ชีพจรเต้นเร็วผิดปกติ!");
    } else if (sp02Avg > 0 && sp02Avg < 93) { 
      terminal.println("Warning: ตรวจพบออกซิเจนต่ำ!");
    } else if (beatAvg > 50 && sp02Avg >= 93) {
      terminal.println("Doctor AI: สัญญาณชีพปกติดีครับ");
    } else {
      terminal.println("Doctor AI: กำลังอ่านค่าเลือด...");  
    }
  }
  terminal.flush();
}

void setup() {
  Serial.begin(115200);
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {  
    Serial.println("MAX30102 ไม่ตอบสนอง!");
    while (1);
  }

  // ตั้งค่าเซ็นเซอร์ให้เร็วปรื๊ด (400 Samples/วินาที)
  particleSensor.setup(60, 4, 2, 400, 411, 4096);

  terminal.clear();
  terminal.println("กําลังคํานวณ...");
  terminal.flush();

  timer.setInterval(1000L, checkHealthAI); // อัปเดตแอปทุกๆ 1 วินาที
}

void loop() {
  Blynk.run(); // เลี้ยงแอป Blynk ตลอดเวลา (หัวใจสำคัญไม่ให้แอปค้าง)** ถึงไม่กดบูทก็ยังทํางานต่อไป
  timer.run();

  // ตรวจสอบว่ามีข้อมูลใหม่จากเซ็นเซอร์เข้ามาหรือยัง? (ถ้ายังไม่มี ก็ข้ามไปเลย ไม่ต้องรอ)
  if (particleSensor.check() > 0) {
    
    // มีข้อมูลใหม่! แวะเก็บ (Buffer)
    redBuffer[bufferIndex] = particleSensor.getRed();
    irBuffer[bufferIndex] = particleSensor.getIR();
    long currentIrValue = irBuffer[bufferIndex];

    // เช็คชีพจรทันที (เช็คทีละจังหวะ)
    if (checkForBeat(currentIrValue) == true) {
      long delta = millis() - lastBeat;
      lastBeat = millis();
      beatsPerMinute = 60 / (delta / 1000.0);
      if (beatsPerMinute < 255 && beatsPerMinute > 20) {
        rates[rateSpot++] = (byte)beatsPerMinute;  
        rateSpot %= 4;
        beatAvg = (rates[0] + rates[1] + rates[2] + rates[3]) / 4;
      }
    }

    bufferIndex++; // ขยับไปช่องถัดไป

    // ถ้าเก็บข้อมูลสะสมครบ 100 ช่องเมื่อไหร่ (ใช้เวลาแค่เสี้ยววินาที) ค่อยเอาไปคำนวณ SpO2
    if (bufferIndex >= 100) {
      maxim_heart_rate_and_oxygen_saturation(irBuffer, 100, redBuffer, &spo2, &validSPO2, &heartRate, &validHeartRate);
      
      if (validSPO2 == 1 && spo2 <= 100 && spo2 > 50) {
        sp02Avg = spo2; // อัปเดตค่า SpO2 ล่าสุด
      }
      
      // ล้างกระเป๋า กลับไปเริ่มเก็บใส่ช่องที่ 0 ใหม่
      bufferIndex = 0; 
    }
  }
}
